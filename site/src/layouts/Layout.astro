---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Peter J. Marino',
  description = 'Professional home page for Peter J. Marino',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        var preferred = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', preferred);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ---- Dark theme (default) ---- */
  [data-theme="dark"] {
    --bg: #0a0a0a;
    --text: #c8c8c8;
    --text-strong: #e8e8e8;
    --muted: #666;
    --line: rgba(255, 255, 255, 0.42);
    --toggle-day: #0dbdf6;
    --toggle-night: #272a30;
  }

  /* ---- Light theme ---- */
  [data-theme="light"] {
    --bg: #fafafa;
    --text: #444;
    --text-strong: #111;
    --muted: #999;
    --line: rgba(0, 0, 0, 0.12);
    --toggle-day: #0dbdf6;
    --toggle-night: #272a30;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    min-height: 100%;
    transition: background 0.3s ease;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    transition: color 0.3s ease;
  }

  a {
    color: var(--text-strong);
    font-weight: 500;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  strong, b {
    color: var(--text-strong);
    font-weight: 600;
  }

  /* Signature swap */
  [data-theme="dark"] .sig-black { display: none; }
  [data-theme="dark"] .sig-white { display: block; }
  [data-theme="light"] .sig-black { display: block; }
  [data-theme="light"] .sig-white { display: none; }
</style>
