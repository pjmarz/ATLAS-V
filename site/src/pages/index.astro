---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title={site.title} description={site.description}>
  <main class="page-shell">
    <section class="hero card">
      <p class="eyebrow">welcometomarz.net</p>
      <h1>{site.headline}</h1>
      <p class="subheadline">{site.subheadline}</p>
      <p class="intro">{site.intro}</p>

      <div class="actions" aria-label="Primary links">
        {site.links.map((link) => (
          <a class="button" href={link.href} target={link.href.startsWith('mailto:') ? undefined : '_blank'} rel={link.href.startsWith('mailto:') ? undefined : 'noreferrer'}>
            {link.label}
          </a>
        ))}
      </div>

      <p class="microcopy">{site.note}</p>
    </section>

    <section class="grid">
      <section class="card section-block">
        <div class="section-header">
          <p class="section-label">Featured projects</p>
          <h2>Current work worth clicking</h2>
        </div>

        <div class="project-list">
          {site.projects.map((project) => (
            <a class="project" href={project.href} target="_blank" rel="noreferrer">
              <div>
                <h3>{project.name}</h3>
                <p>{project.summary}</p>
              </div>
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </section>

      <section class="card section-block sidebar">
        <div class="section-header">
          <p class="section-label">Quick facts</p>
          <h2>Concise by design</h2>
        </div>

        <ul class="facts">
          <li>Falls Church, Virginia</li>
          <li>Product, automation, AI, and cloud focus</li>
          <li>Built as a minimal replacement for Linktree</li>
        </ul>

        <div class="contact-box">
          <p class="contact-label">Public contact</p>
          <a href={site.email}>peter.marino2@gmail.com</a>
        </div>
      </section>
    </section>
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1100px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 4rem;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  .hero {
    padding: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow,
  .section-label,
  .contact-label,
  .microcopy {
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .eyebrow,
  .section-label,
  .contact-label {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 700;
  }

  h1 {
    margin: 0.35rem 0 0;
    font-size: clamp(2.5rem, 6vw, 4.6rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .subheadline {
    margin: 1rem 0 0;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--accent);
    font-weight: 600;
  }

  .intro {
    max-width: 62ch;
    margin: 1.25rem 0 0;
    color: #d6e2f0;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 1.75rem;
  }

  .button {
    text-decoration: none;
    padding: 0.85rem 1.15rem;
    border-radius: 999px;
    border: 1px solid rgba(125, 211, 252, 0.24);
    background: linear-gradient(180deg, rgba(125, 211, 252, 0.18), rgba(125, 211, 252, 0.08));
    font-weight: 700;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .button:hover {
    transform: translateY(-1px);
    border-color: rgba(125, 211, 252, 0.48);
    background: linear-gradient(180deg, rgba(125, 211, 252, 0.26), rgba(125, 211, 252, 0.1));
  }

  .microcopy {
    margin: 1.2rem 0 0;
    font-size: 0.95rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 1.5rem;
  }

  .section-block {
    padding: 1.75rem;
  }

  .section-header h2 {
    margin: 0.45rem 0 0;
    font-size: 1.6rem;
  }

  .project-list {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .project {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.15rem;
    border-radius: 18px;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    text-decoration: none;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease;
  }

  .project:hover {
    transform: translateY(-2px);
    border-color: rgba(167, 139, 250, 0.45);
  }

  .project h3 {
    margin: 0;
    font-size: 1.1rem;
  }

  .project p,
  .facts li,
  .contact-box a {
    color: #d6e2f0;
    line-height: 1.65;
  }

  .project p {
    margin: 0.45rem 0 0;
  }

  .arrow {
    color: var(--accent-2);
    font-size: 1.2rem;
    line-height: 1;
  }

  .facts {
    margin: 1.5rem 0 0;
    padding-left: 1.1rem;
  }

  .facts li + li {
    margin-top: 0.7rem;
  }

  .contact-box {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }

  .contact-box a {
    display: inline-block;
    margin-top: 0.55rem;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .page-shell {
      width: min(100% - 1rem, 1100px);
      padding: 1rem 0 2rem;
    }

    .hero,
    .section-block {
      padding: 1.35rem;
    }

    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
