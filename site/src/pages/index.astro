---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title={site.title} description={site.description}>
  <main>
    <div class="container">
      <!-- Theme toggle — animated sun/moon/cloud/star pill -->
      <button class="theme-switcher" id="theme-toggle" aria-label="Switch theme">
        <div class="sun"></div>
        <div class="moon-overlay"></div>
        <div class="cloud-ball" id="ball1"></div>
        <div class="cloud-ball" id="ball2"></div>
        <div class="cloud-ball" id="ball3"></div>
        <div class="cloud-ball" id="ball4"></div>
        <div class="star" id="star1"></div>
        <div class="star" id="star2"></div>
        <div class="star" id="star3"></div>
        <div class="star" id="star4"></div>
      </button>

      <!-- Header: name + signature -->
      <header>
        <div class="header-row">
          <h1>peter j. marino</h1>
          <div class="signature">
            <img class="sig-black" src="/sig-black.png" alt="PJM signature" />
            <img class="sig-white" src="/sig-white.png" alt="PJM signature" />
          </div>
        </div>
        <hr />
      </header>

      <!-- About -->
      <section>
        <h2>about</h2>
        <p>Senior Product Manager focused on automation, AI, and cloud infrastructure.</p>
        <p>Previously DOD Secret & DHS Public Trust Cleared.</p>
        <p>I also enjoy Star Wars, long walks on the beach, and a strong Mai Tai.</p>
      </section>

      <!-- Projects -->
      <section>
        <h2>projects</h2>
        <p>
          <a href="https://github.com/pjmarz/LUMINAL" target="_blank" rel="noreferrer">LUMINAL</a> | self-hosted systems and automation environment
        </p>
        <ul>
          <li>a project directory and service environment built to develop, run, and refine automation, AI, and orchestration workflows</li>
          <li>integrates open-source tools and custom services into a practical workspace for experimentation and day-to-day use</li>
        </ul>

        <p class="project-entry">
          <a href="https://github.com/pjmarz/HELIOS" target="_blank" rel="noreferrer">HELIOS</a> | self-hosted media and infrastructure environment
        </p>
        <ul>
          <li>a project directory and service environment built to operate and manage a media stack and related homelab services</li>
          <li>brings together open-source software like Radarr, Sonarr, and other supporting tools in a setup focused on reliability and automation</li>
        </ul>

        <p class="project-entry">
          <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noreferrer">OpenClaw</a> | personal AI assistant and automation workflows
        </p>
        <ul>
          <li>used as a persistent personal assistant for daily coordination, research, and project work</li>
          <li>supports chat-based automation, background tasks, and hands-on management across homelab and personal systems</li>
        </ul>
      </section>

      <!-- Links -->
      <section>
        <h2>links</h2>
        <p>
          <a href="https://linkedin.com/in/pjmarz" target="_blank" rel="noreferrer">linkedin</a> |
          <a href="https://github.com/pjmarz" target="_blank" rel="noreferrer">github</a> |
          <a href="mailto:peter.marino2@gmail.com">email</a>
        </p>
      </section>
    </div>
  </main>
</Layout>

<script>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    // Sync toggle class with initial theme
    if (document.documentElement.getAttribute('data-theme') === 'dark') {
      toggle.classList.add('night');
    }
    toggle.addEventListener('click', () => {
      toggle.classList.toggle('night');
      const isDark = toggle.classList.contains('night');
      document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }
</script>

<style>
  main {
    min-height: 100vh;
    padding-top: clamp(60px, 15vh, 140px);
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 32px 60px;
  }

  /* ---- Header ---- */
  header {
    margin-bottom: 48px;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  h1 {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 400;
    color: var(--text-strong);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .signature img {
    height: 70px;
    width: auto;
    border-radius: 4px;
  }

  hr {
    border: none;
    border-top: 1px solid var(--line);
  }

  /* ---- Toggle — animated sun/moon/cloud/star pill ---- */
  .theme-switcher {
    position: fixed;
    top: 20px;
    right: 24px;
    z-index: 100;
    display: grid;
    grid-template-columns: repeat(54, 1px);
    grid-template-rows: repeat(24, 1px);
    gap: 0;
    background-color: var(--toggle-day);
    border-radius: 49px;
    border: 1px solid var(--line);
    cursor: pointer;
    transition: background-color 0.8s ease, border-color 0.8s ease;
    appearance: none;
    padding: 0;
  }

  .theme-switcher.night {
    background-color: var(--toggle-night);
  }

  /* Sun / Moon circle */
  .sun {
    background-color: #fabc1c;
    grid-column: 3 / 23;
    grid-row: 3 / 23;
    border-radius: 50%;
    transition: grid-column 0.8s ease, background-color 0.8s ease;
    height: 20px;
  }

  .theme-switcher.night .sun {
    grid-column: 33 / 53;
    background-color: #fffdf2;
  }

  /* Moon crescent overlay */
  .moon-overlay {
    position: absolute;
    border-radius: 50%;
    width: 0;
    height: 0;
    transition: left 0.8s ease, background-color 0.8s ease, width 0.8s ease, height 0.8s ease;
    z-index: 1;
    background-color: var(--toggle-day);
  }

  .theme-switcher.night .moon-overlay {
    left: calc(28 / 54 * 100%);
    top: calc(4 / 29 * 100%);
    width: 18px;
    height: 18px;
    background-color: var(--toggle-night);
  }

  /* Cloud balls → shrink to stars */
  .cloud-ball {
    background-color: #fffdf2;
    border-radius: 50%;
    width: 9px;
    height: 9px;
    position: absolute;
    transition: all 0.8s ease;
    z-index: 2;
  }

  #ball1 { top: calc(8 / 24 * 100%); left: calc(12 / 54 * 100%); }
  #ball2 { top: calc(8 / 24 * 100%); left: calc(17 / 54 * 100%); }
  #ball3 { top: calc(8 / 24 * 100%); left: calc(22 / 54 * 100%); }
  #ball4 { top: calc(6 / 24 * 100%); left: calc(17 / 54 * 100%); }

  .theme-switcher.night #ball1 { top: calc(16 / 24 * 100%); left: calc(16 / 54 * 100%); width: 2px; height: 2px; }
  .theme-switcher.night #ball2 { top: calc(3 / 24 * 100%); left: calc(22 / 54 * 100%); width: 2px; height: 2px; }
  .theme-switcher.night #ball3 { top: calc(10 / 24 * 100%); left: calc(29 / 54 * 100%); width: 2px; height: 2px; }
  .theme-switcher.night #ball4 { top: calc(5 / 24 * 100%); left: calc(34 / 54 * 100%); width: 2px; height: 2px; }

  /* Stars — fade in on dark mode */
  .star {
    background-color: #fffdf2;
    width: 1px;
    height: 1px;
    position: absolute;
    opacity: 0;
    border-radius: 50%;
    transition: opacity 0.8s ease;
  }

  #star1 { top: calc(7 / 24 * 100%); left: calc(10 / 54 * 100%); }
  #star2 { top: calc(9 / 24 * 100%); left: calc(16 / 54 * 100%); }
  #star3 { top: calc(13 / 24 * 100%); left: calc(23 / 54 * 100%); }
  #star4 { top: calc(18 / 24 * 100%); left: calc(29 / 54 * 100%); }

  .theme-switcher.night #star1,
  .theme-switcher.night #star2,
  .theme-switcher.night #star3,
  .theme-switcher.night #star4 { opacity: 1; }

  /* ---- Sections ---- */
  section {
    margin-bottom: 40px;
  }

  h2 {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(20px, 3vw, 24px);
    font-weight: 400;
    color: var(--text-strong);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  p {
    margin-bottom: 8px;
  }

  .muted {
    color: var(--muted);
    font-size: 14px;
    margin-top: 4px;
  }

  .personal {
    font-style: italic;
    color: var(--muted);
  }

  .project-entry {
    margin-top: 20px;
  }

  ul {
    padding-left: 20px;
    margin-top: 4px;
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 14px;
  }

  li {
    margin-bottom: 2px;
  }

  /* ---- Mobile ---- */
  @media (max-width: 480px) {
    .signature img {
      height: 55px;
    }

    .header-row {
      gap: 12px;
    }
  }
</style>
