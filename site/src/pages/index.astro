---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
import { projects } from '../data/projects';
import sigBlack from '../assets/sig-black.png';

const technicalProjects = projects.filter((project) => project.category === 'technical');
const initiatives = projects.filter((project) => project.category === 'initiative');
---

<Layout title={site.title} description={site.description}>
  <div class="shell">
    <input id="dark-mode" class="toggle" type="checkbox" role="switch" aria-label="Dark mode" checked />

    <main>
      <header>
        <div class="header-row">
          <h1 class="wordmark">peter j. marino</h1>
          <Image class="signature" src={sigBlack} alt="PJM signature" width={208} densities={[1, 2]} />
        </div>
        <hr />
      </header>

      <section class="about">
        <h2>about</h2>
        <p>Senior Product Manager focused on automation, AI, and cloud infrastructure.</p>
        <p>Previously DOD Secret &amp; DHS Public Trust Cleared.</p>
        <p>I also enjoy Star Wars, long walks on the beach, and a strong Mai Tai.</p>
      </section>

      <section>
        <h2>technical projects</h2>
        <div class="projects">
          {technicalProjects.map((project) => (
            <article class="project">
              <div class="title">
                {project.href ? <a href={project.href} target="_blank" rel="noreferrer">{project.title}</a> : project.title}
              </div>
              <div class="tagline">{project.tagline}</div>
              <ul class="project-notes">
                {project.notes.map((note) => <li>{note}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section>
        <h2>strategic initiatives</h2>
        <div class="projects">
          {initiatives.map((project) => (
            <article class="project initiative">
              <div class="title">{project.title}</div>
              <div class="tagline">{project.tagline}</div>
              <ul class="project-notes">
                {project.notes.map((note) => <li>{note}</li>)}
              </ul>
              {project.artifacts && (
                <div class="project-artifacts">
                  {project.artifacts.map((artifact) => (
                    <a
                      href={artifact.href}
                      data-doc-preview
                      data-doc-title={`${project.title}, ${artifact.label}`}
                    >
                      {artifact.label}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="links-section">
        <div class="links-icons">
          <a href="https://linkedin.com/in/pjmarz" target="_blank" rel="noreferrer" aria-label="LinkedIn" title="LinkedIn">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.22 0z" />
            </svg>
            <span class="sr">LinkedIn</span>
          </a>
          <a href="https://github.com/pjmarz" target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
              <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.22.69.82.58A12 12 0 0 0 12 .3" />
            </svg>
            <span class="sr">GitHub</span>
          </a>
          <a href="mailto:peter.marino2@gmail.com" aria-label="Email" title="Email">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2.5" y="5" width="19" height="14" rx="1.5" />
              <path d="m3.5 6.5 8.5 6.5 8.5-6.5" />
            </svg>
            <span class="sr">Email</span>
          </a>
        </div>
      </section>

      <dialog class="doc-modal" id="doc-preview-modal" aria-labelledby="doc-preview-title">
        <div class="doc-modal__surface">
          <div class="doc-modal__header">
            <div>
              <p class="doc-modal__eyebrow">artifact preview</p>
              <h3 id="doc-preview-title">Document preview</h3>
            </div>
            <button type="button" class="doc-modal__close" data-doc-close aria-label="Close document preview">close</button>
          </div>
          <div class="doc-modal__body">
            <iframe id="doc-preview-frame" title="Initiative artifact preview" loading="lazy" referrerpolicy="no-referrer"></iframe>
          </div>
        </div>
      </dialog>

      <div class="colophon">
        <span>
          made with
          <svg class="heart" viewBox="0 0 24 24" width="11" height="11" aria-label="love" role="img"><path fill="currentColor" d="M12 21s-7.5-4.6-10-10a5.5 5.5 0 0 1 10-3.5A5.5 5.5 0 0 1 22 11c-2.5 5.4-10 10-10 10z" /></svg>
        </span>
      </div>
    </main>

    <div class="curtain"></div>
  </div>
</Layout>

<script is:inline>
  const modal = document.getElementById('doc-preview-modal');
  const frame = document.getElementById('doc-preview-frame');
  const title = document.getElementById('doc-preview-title');
  const closeButton = document.querySelector('[data-doc-close]');
  const openers = document.querySelectorAll('[data-doc-preview]');

  const buildPreviewSrc = (href) => href;

  const resetPreview = () => {
    document.documentElement.classList.remove('has-doc-modal');
    if (frame instanceof HTMLIFrameElement) {
      frame.setAttribute('src', 'about:blank');
    }
    if (title instanceof HTMLElement) {
      title.textContent = 'Document preview';
    }
  };

  const closePreview = () => {
    if (!(modal instanceof HTMLDialogElement) || !modal.open) return;
    if (modal.classList.contains('is-closing')) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      modal.close();
      return;
    }

    modal.classList.add('is-closing');
    const onEnd = (event) => {
      if (event.target !== modal) return;
      modal.removeEventListener('animationend', onEnd);
      modal.classList.remove('is-closing');
      modal.close();
    };
    modal.addEventListener('animationend', onEnd);
  };

  if (modal instanceof HTMLDialogElement && frame instanceof HTMLIFrameElement && title instanceof HTMLElement) {
    const mobileQuery = window.matchMedia('(max-width: 640px)');

    openers.forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href');
        if (!href) {
          return;
        }

        event.preventDefault();

        if (mobileQuery.matches) {
          window.open(href, '_blank', 'noopener');
          return;
        }

        title.textContent = link.getAttribute('data-doc-title') || 'Document preview';
        frame.setAttribute('src', buildPreviewSrc(href));
        document.documentElement.classList.add('has-doc-modal');
        modal.showModal();
      });
    });

    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        closePreview();
      }
    });

    modal.addEventListener('cancel', (event) => {
      event.preventDefault();
      closePreview();
    });

    modal.addEventListener('close', resetPreview);
    closeButton?.addEventListener('click', closePreview);
  }
</script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; border: 0; }
  html, body { min-height: 100%; }

  :root {
    --paper: #e8e6e1;
    --ink: #141210;
    --ink-soft: #4a4641;
    --ink-faint: #8a857d;
    --rule: rgba(20, 18, 16, 0.14);
    --rule-strong: rgba(20, 18, 16, 0.28);
  }

  html.has-doc-modal,
  html.has-doc-modal body {
    overflow: hidden;
  }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: "ss01", "cv11";
  }

  .shell { position: relative; min-height: 100vh; }

  .curtain {
    position: absolute;
    inset: 0;
    background: #ffffff;
    mix-blend-mode: difference;
    pointer-events: none;
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 420ms cubic-bezier(0.65, 0, 0.1, 1);
    z-index: 150;
  }
  .toggle:checked ~ .curtain { transform: scaleX(1); }
  .sr { position: absolute; width: 1px; height: 1px; clip: rect(1px, 1px, 1px, 1px); overflow: hidden; }
  .toggle {
    -webkit-appearance: none;
    appearance: none;
    position: absolute;
    top: 22px;
    right: 24px;
    width: 40px;
    height: 22px;
    border-radius: 999px;
    cursor: pointer;
    background: transparent;
    border: 1px solid var(--rule-strong);
    border-radius: 18px;
    z-index: 100;
    transition: border-color 200ms ease;
    -webkit-tap-highlight-color: transparent;
  }
  .toggle::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--ink);
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .toggle:checked::after { transform: translateX(18px); }
  .toggle:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(56px, 10vh, 96px) 32px clamp(72px, 10vh, 120px);
  }
  header { margin-bottom: 40px; }
  .header-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 24px;
    margin-bottom: 24px;
  }
  .wordmark {
    font-family: 'EB Garamond', Georgia, serif;
    font-weight: 400;
    font-size: clamp(32px, 5vw, 44px);
    line-height: 1;
    letter-spacing: -0.015em;
  }
  .signature {
    width: 104px;
    height: auto;
    opacity: 0.92;
    transform: translateY(18px) rotate(-2deg);
    transform-origin: bottom right;
  }
  header hr {
    border-top: 1px solid var(--rule);
    width: 100%;
  }
  section { margin-bottom: 40px; }
  section:last-of-type { margin-bottom: 0; }
  h2 {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: lowercase;
    color: var(--ink-faint);
    margin-bottom: 20px;
  }
  .about p {
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 10px;
    color: var(--ink);
    max-width: 56ch;
  }
  .projects { border-top: 1px solid var(--rule); }
  .project {
    padding: 22px 0;
    border-bottom: 1px solid var(--rule);
  }
  .project .title {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 22px;
    line-height: 1.2;
    margin-bottom: 6px;
  }
  .project .title a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 160ms ease;
  }
  .project .title a:hover { border-color: currentColor; }
  .tagline {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 14px;
    text-transform: lowercase;
  }
  .project-notes {
    padding-left: 18px;
    color: var(--ink);
  }
  .project-notes li {
    margin-bottom: 8px;
    font-size: 14px;
    line-height: 1.7;
  }
  .project-artifacts {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 16px;
  }
  .project-artifacts a {
    font-size: 13px;
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-strong);
  }
  .project-artifacts a:hover { color: var(--ink); border-color: currentColor; }
  .links-section {
    display: flex;
    justify-content: center;
    padding-top: 4px;
  }
  .links-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--ink-faint);
  }
  .links-icons a {
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 160ms ease, transform 160ms ease;
  }
  .links-icons a:hover {
    color: var(--ink);
    transform: translateY(-1px);
  }
  .doc-modal {
    inset: 0;
    margin: auto;
    width: min(1040px, calc(100vw - 32px));
    max-width: 1040px;
    height: min(88vh, 920px);
    max-height: 920px;
    padding: 0;
    border: 1px solid var(--rule-strong);
    border-radius: 18px;
    background: var(--paper);
    color: var(--ink);
    box-shadow: 0 30px 90px rgba(12, 11, 10, 0.28);
    transform-origin: center center;
  }
  .toggle:checked ~ main .doc-modal {
    --paper: #141210;
    --ink: #e8e6e1;
    --ink-soft: #b7b4ae;
    --ink-faint: #7a756d;
    --rule: rgba(232, 230, 225, 0.14);
    --rule-strong: rgba(232, 230, 225, 0.28);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
  }
  .toggle:checked ~ main .doc-modal[open]::backdrop {
    background: rgba(0, 0, 0, 0.68);
  }
  .toggle:checked ~ main .doc-modal__body iframe {
    background: #1d1b18;
  }
  @keyframes doc-iris-in {
    from { opacity: 0; transform: scale(0.72); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes doc-iris-out {
    from { opacity: 1; transform: scale(1); }
    to   { opacity: 0; transform: scale(0.72); }
  }
  @keyframes doc-backdrop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes doc-backdrop-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  .doc-modal[open] {
    animation: doc-iris-in 320ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .doc-modal[open]::backdrop {
    background: rgba(20, 18, 16, 0.52);
    backdrop-filter: blur(3px);
    animation: doc-backdrop-in 260ms linear;
  }
  .doc-modal.is-closing {
    animation: doc-iris-out 220ms ease-in forwards;
  }
  .doc-modal.is-closing::backdrop {
    animation: doc-backdrop-out 220ms linear forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .doc-modal[open],
    .doc-modal[open]::backdrop,
    .doc-modal.is-closing,
    .doc-modal.is-closing::backdrop {
      animation-duration: 0ms;
    }
  }
  .doc-modal__surface {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .doc-modal__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: 20px 22px;
    border-bottom: 1px solid var(--rule);
  }
  .doc-modal__eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 6px;
  }
  .doc-modal h3 {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.1;
    font-weight: 400;
  }
  .doc-modal__close {
    background: transparent;
    color: var(--ink-soft);
    border: 1px solid var(--rule-strong);
    border-radius: 999px;
    padding: 8px 14px;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .doc-modal__close:hover {
    color: var(--ink);
    border-color: currentColor;
  }
  .doc-modal__close:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
  }
  .doc-modal__body {
    flex: 1;
    min-height: 0;
    padding: 0 22px 22px;
  }
  .doc-modal__body iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: #f8f7f4;
    border-radius: 12px;
  }
  .colophon {
    margin-top: 44px;
    color: var(--ink-faint);
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: lowercase;
    text-align: center;
  }
  .heart { transform: translateY(1px); }
  @media (max-width: 640px) {
    main { padding-inline: 22px; }
    .header-row {
      gap: 12px;
    }
    .signature {
      width: 72px;
    }
    .toggle {
      top: 18px;
      right: 18px;
    }
    .doc-modal {
      width: calc(100vw - 18px);
      height: calc(100vh - 28px);
    }
    .doc-modal__header,
    .doc-modal__body {
      padding-inline: 16px;
    }
    .doc-modal__header {
      padding-top: 16px;
      padding-bottom: 16px;
    }
    .doc-modal__body {
      padding-bottom: 16px;
    }
  }
</style>
