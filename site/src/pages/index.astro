---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title={site.title} description={site.description}>
  <form>
    <!-- Toggle must come first so ~ sibling selector can reach .curtain -->
    <input id="dark-mode" class="toggle" type="checkbox" name="Dark mode" role="switch" value="on" />
    <label for="dark-mode" class="sr">Dark Mode</label>

    <!-- Site content -->
    <main>
      <header>
        <div class="header-row">
          <h1>peter j. marino</h1>
          <div class="signature">
            <img src="/sig-black.png" alt="PJM signature" />
          </div>
        </div>
        <hr />
      </header>

      <section>
        <h2>about</h2>
        <p>Senior Product Manager focused on automation, AI, and cloud infrastructure.</p>
        <p>Previously DOD Secret & DHS Public Trust Cleared.</p>
        <p>I also enjoy Star Wars, long walks on the beach, and a strong Mai Tai.</p>
      </section>

      <section>
        <h2>projects</h2>
        <p>
          <a href="https://github.com/pjmarz/LUMINAL" target="_blank" rel="noreferrer">LUMINAL</a> | self-hosted systems and automation environment
        </p>
        <ul>
          <li>a project directory and service environment built to develop, run, and refine automation, AI, and orchestration workflows</li>
          <li>integrates open-source tools and custom services into a practical workspace for experimentation and day-to-day use</li>
        </ul>

        <p class="project-entry">
          <a href="https://github.com/pjmarz/HELIOS" target="_blank" rel="noreferrer">HELIOS</a> | self-hosted media and infrastructure environment
        </p>
        <ul>
          <li>a project directory and service environment built to operate and manage a media stack and related homelab services</li>
          <li>brings together open-source software like Radarr, Sonarr, and other supporting tools in a setup focused on reliability and automation</li>
        </ul>

        <p class="project-entry">
          <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noreferrer">OpenClaw</a> | personal AI assistant and automation workflows
        </p>
        <ul>
          <li>used as a persistent personal assistant for daily coordination, research, and project work</li>
          <li>supports chat-based automation, background tasks, and hands-on management across homelab and personal systems</li>
        </ul>
      </section>

      <section>
        <h2>links</h2>
        <p>
          <a href="https://linkedin.com/in/pjmarz" target="_blank" rel="noreferrer">linkedin</a> |
          <a href="https://github.com/pjmarz" target="_blank" rel="noreferrer">github</a> |
          <a href="mailto:peter.marino2@gmail.com">email</a>
        </p>
      </section>
    </main>

    <!-- Curtain must come LAST so `.toggle:checked ~ .curtain` reaches it -->
    <div class="curtain"></div>
  </form>
</Layout>

<style is:global>
  /* ---- CodePen base (unchanged) ---- */
  * {
    border: 0;
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  :root {
    --dur: 0.3s;
  }
  body, input {
    color: hsl(0, 0%, 10%);
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }
  body {
    background: hsl(0, 0%, 90%);
    min-height: 100vh;
  }

  form, .toggle:before, .toggle:after {
    background: hsl(0, 0%, 90%);
  }
  form, .toggle {
    position: relative;
  }
  form {
    min-height: 100vh;
  }

  .curtain, .sr, .toggle:before, .toggle:after {
    position: absolute;
  }
  .curtain, .toggle:before, .toggle:after {
    transition: transform var(--dur);
  }
  .curtain, .toggle:before, .toggle:checked:after {
    transition-timing-function: ease-out;
  }
  .curtain, .sr {
    top: 0;
    left: 0;
  }

  /* Curtain — full page, sweeps via mix-blend-mode: difference */
  .curtain {
    background: hsl(0, 0%, 100%);
    mix-blend-mode: difference;
    pointer-events: none;
    width: 100%;
    height: 100%;
    position: fixed;
    transform: scaleX(0);
    transform-origin: 0 50%;
    z-index: 999;
  }

  .sr, .toggle {
    overflow: hidden;
  }
  .sr {
    clip: rect(1px, 1px, 1px, 1px);
    color: transparent;
    width: 1px;
    height: 1px;
  }

  /* Toggle — fixed top-right */
  .toggle {
    background: currentColor;
    border-radius: 0.75em;
    cursor: pointer;
    width: 3em;
    height: 1.5em;
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
    position: fixed;
    top: 20px;
    right: 24px;
    z-index: 100;
    font-size: 18px;
  }
  .toggle:before, .toggle:after {
    border-radius: 50%;
    content: "";
    display: block;
    top: 0.25em;
    left: 0.25em;
    width: 1em;
    height: 1em;
  }
  .toggle:before, .toggle:checked:after {
    transition-delay: 0s;
  }
  .toggle:checked:before, .toggle:after {
    transition-delay: calc(var(--dur) * 0.75);
    transition-timing-function: cubic-bezier(0.3, 1.6, 0.5, 0.7);
  }
  .toggle:before {
    transform: translateX(-1.5em);
  }
  .toggle:checked:before {
    transform: translateX(1.5em);
  }
  .toggle:checked:after {
    transform: translateX(3em);
  }
  .toggle:checked ~ .curtain {
    transform: scaleX(1);
  }
  .toggle:focus {
    outline: transparent;
  }

  /* ---- Site content ---- */
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(80px, 15vh, 150px) 32px 60px;
  }

  header {
    margin-bottom: 48px;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  h1 {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .signature img {
    height: 70px;
    width: auto;
    border-radius: 4px;
  }

  hr {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.15);
  }

  section {
    margin-bottom: 40px;
  }

  h2 {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(20px, 3vw, 24px);
    font-weight: 400;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  p {
    margin-bottom: 8px;
  }

  a {
    color: inherit;
    font-weight: 500;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  strong, b {
    font-weight: 600;
  }

  .project-entry {
    margin-top: 20px;
  }

  ul {
    padding-left: 20px;
    margin-top: 4px;
    margin-bottom: 8px;
    font-size: 14px;
  }

  li {
    margin-bottom: 2px;
  }

  @media (max-width: 480px) {
    .signature img {
      height: 55px;
    }
    .header-row {
      gap: 12px;
    }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
